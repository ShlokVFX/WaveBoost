ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda-12.4/bin/nvcc

cflags = -DTORCH_EXTENSION_NAME=flash_attn -DTORCH_API_INCLUDE_EXTENSION_H -isystem /root/venvs/torch/lib/python3.12/site-packages/torch/include -isystem /root/venvs/torch/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -isystem /usr/local/cuda-12.4/include -isystem /usr/include/python3.12 -fPIC -std=c++17
post_cflags = 
cuda_cflags = -DTORCH_EXTENSION_NAME=flash_attn -DTORCH_API_INCLUDE_EXTENSION_H -isystem /root/venvs/torch/lib/python3.12/site-packages/torch/include -isystem /root/venvs/torch/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -isystem /usr/local/cuda-12.4/include -isystem /usr/include/python3.12 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 --compiler-options '-fPIC' -O2 -std=c++17
cuda_post_cflags = 
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = -shared -L/root/venvs/torch/lib/python3.12/site-packages/torch/lib -lc10 -lc10_cuda -ltorch_cpu -ltorch_cuda -ltorch -ltorch_python -L/usr/local/cuda-12.4/lib64 -lcudart

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





rule link
  command = $cxx $in $ldflags -o $out

build main.o: compile /mnt/d/GITHUB/WaveBoost/test/cuda/main.cpp
build cuda.cuda.o: cuda_compile /mnt/d/GITHUB/WaveBoost/test/cuda/cuda.cu





build flash_attn.so: link main.o cuda.cuda.o

default flash_attn.so
